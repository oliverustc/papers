# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# MinerU PDF 转换 API
MINERU_URL=https://api.example.com/mineru/file_parse
MINERU_TOKEN=your-mineru-token-here

# LLM 笔记生成 API（OpenAI-compatible）
LLM_URL=https://api.example.com/v1/chat/completions
LLM_TOKEN=your-llm-token-here
LLM_MODEL=deepseek-v4-flash-ascend

# Zotero 本地路径（WSL 用户按实际路径修改）
ZOTERO_DB=/mnt/c/Users/<username>/Zotero/zotero.sqlite
ZOTERO_STORE=/mnt/c/Users/<username>/Zotero/storage

# Unpaywall API（免费，无需注册，填入真实邮箱即可）
UNPAYWALL_EMAIL=your@email.com
